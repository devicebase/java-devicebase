# Auto detect text files and perform LF normalization
* text=auto

# Java files
*.java text eol=lf

# Gradle files
*.gradle text eol=lf
*.gradle.kts text eol=lf

# Shell scripts
*.sh text eol=lf

# Properties files
*.properties text eol=lf

# XML files
*.xml text eol=lf

# JSON files
*.json text eol=lf

# Markdown files
*.md text eol=lf

# Maven Wrapper
mvnw text eol=lf
mvnw.cmd text eol=crlf

# IDE
*.iml text eol=lf
*.ipr text eol=lf
*.iws text eol=lf
.idea/* text eol=lf
.vscode/* text eol=lf

# Binary files
*.class binary
*.jar binary
*.war binary
*.ear binary
*.zip binary
*.tar.gz binary
*.rar binary